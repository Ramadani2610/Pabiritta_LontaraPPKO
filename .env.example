# Flask
FLASK_ENV=production
SECRET_KEY=ganti-dengan-string-acak-yang-panjang-dan-rahasia

# Database PostgreSQL (Neon)
# Dapatkan dari: neon.tech → Dashboard → Connection String
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Cloudinary (untuk upload foto laporan)
# Dapatkan dari: cloudinary.com → Dashboard → Account Details
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# API Key untuk endpoint sensor ESP32 (EWS)
SENSOR_API_KEY=ganti-dengan-api-key-rahasia-untuk-esp32

# Upload
MAX_UPLOAD_MB=5